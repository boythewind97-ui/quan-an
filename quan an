
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2Q-Phở | ベトナム料理店</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-red: #d32f2f;
            --dark-red: #b71c1c;
            --primary-green: #2e7d32;
            --bg-color: #fffaf0;
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-muted: #666666;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background-color: var(--bg-color);
            background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23e8dec9" fill-opacity="0.4"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
            color: var(--text-main);
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        header {
            background-color: var(--primary-green);
            background-image: linear-gradient(135deg, var(--primary-green) 0%, #43a047 100%);
            color: white;
            text-align: center;
            padding: 3rem 1rem 2rem;
            border-bottom: 8px solid var(--primary-red);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        /* [UPDATED] Logo to hơn */
        .logo-img {
            width: 240px; 
            height: 240px;
            object-fit: contain;
            background-color: #000;
            border-radius: 50%;
            border: 5px solid white;
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
            margin-bottom: 1rem;
        }

        h1 {
            font-size: 3rem;
            font-weight: 900;
            margin: 0;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            font-family: 'Arial Black', sans-serif;
            color: #fff;
        }

        h1 span {
            color: var(--primary-red);
        }

        .subtitle {
            font-size: 1.2rem;
            font-weight: 700;
            background-color: white;
            color: var(--primary-green);
            display: inline-block;
            padding: 5px 20px;
            border-radius: 20px;
            margin-top: 10px;
        }

        .container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .menu-section {
            margin-bottom: 3rem;
        }

        .menu-title {
            text-align: center;
            color: var(--primary-green);
            font-size: 2rem;
            border-bottom: 3px dashed var(--primary-green);
            padding-bottom: 10px;
            margin-bottom: 2rem;
            text-transform: uppercase;
            font-weight: 900;
        }

        .menu-item {
            background-color: var(--card-bg);
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: flex-start; 
            align-items: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-left: 6px solid var(--primary-red);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .menu-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
        }

        /* [UPDATED] Ảnh món ăn to hơn */
        .item-image {
            width: 130px; 
            height: 130px;
            object-fit: cover;
            border-radius: 10px;
            margin-right: 1.5rem; 
            border: 3px solid white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            background-color: #f5f5f5; /* Màu nền phụ khi ảnh chưa tải xong */
        }

        .item-info {
            flex: 1; 
        }

        .item-info h3 {
            margin: 0;
            font-size: 1.4rem;
            color: var(--dark-red);
            font-weight: 800;
            text-align: left;
        }

        .item-info p {
            margin: 5px 0 0;
            color: var(--text-muted);
            font-size: 1rem;
            font-weight: 700;
            text-align: left;
        }

        .item-price {
            margin-left: auto; 
            background-color: var(--primary-red);
            color: white;
            font-size: 1.3rem;
            font-weight: 900;
            padding: 8px 18px;
            border-radius: 30px;
            box-shadow: 0 4px 6px rgba(211, 47, 47, 0.3);
            white-space: nowrap;
        }

        footer {
            background-color: var(--text-main);
            color: white;
            text-align: center;
            padding: 2.5rem 1rem;
            margin-top: 4rem;
            border-top: 5px solid var(--primary-green);
        }

        .footer-section {
            margin-bottom: 20px;
        }

        .footer-label {
            font-size: 0.9rem;
            color: #aaa;
            margin-bottom: 5px;
        }

        .address-text {
            font-size: 1.1rem;
            line-height: 1.4;
            font-weight: 700;
        }

        .owner-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: #ffca28; 
        }

        .phone-number {
            font-size: 1.8rem;
            font-weight: 900;
            color: #ffca28;
            margin-top: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        /* Responsive cho thiết bị di động */
        @media (max-width: 600px) {
            .menu-item {
                flex-direction: column;
                text-align: center;
                gap: 10px;
            }
            .item-image {
                margin-right: 0;
                margin-bottom: 10px;
                width: 150px; /* To hơn chút nữa trên mobile cho rõ */
                height: 150px;
            }
            .item-info h3, .item-info p {
                text-align: center;
            }
            .item-price {
                margin-left: 0;
                margin-top: 10px;
            }
            h1 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>

    <header>
        <img src="logo2.png" alt="Logo 2Q-Phở" class="logo-img">
        <h1>2Q-Phở</h1>
